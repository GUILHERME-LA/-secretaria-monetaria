# Modo demo (true = funciona sem banco, dados mockados)
NEXT_PUBLIC_DEMO_MODE=true

# Conexão Supabase (necessário apenas quando DEMO_MODE=false)
# NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Connection string PostgreSQL direta (necessário apenas quando DEMO_MODE=false)
# DATABASE_URL=postgresql://postgres:senha@db.seu-projeto.supabase.co:5432/postgres

# Ollama Cloud API (opcional, para chat com IA)
# OLLAMA_API_KEY=sua-chave-aqui
# OLLAMA_MODEL=qwen3:8b-cloud
